  "dependencies": {
    "flag-icons": "7.5.0",
    "jose": "6.1.3",
    "next": "16.1.6",
    "next-intl": "4.8.3",
    "primeflex": "4.0.0",
    "primeicons": "7.0.0",
    "primereact": "10.9.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "minimatch@<3.1.4": "3.1.4",
