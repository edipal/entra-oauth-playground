{
  "name": "entra-oauth-playground",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "SASS_SILENCE_DEPRECATIONS=import,legacy-js-api next dev --experimental-https",
    "build": "SASS_SILENCE_DEPRECATIONS=import,legacy-js-api next build",
    "start": "next start",
    "format": "prettier --write \"{app,demo,layout,types,src}/**/*.{js,ts,tsx,d.ts}\"",
    "lint": "eslint ."
